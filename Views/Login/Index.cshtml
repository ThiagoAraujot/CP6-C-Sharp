@model LoginViewModel
@{
    ViewData["Title"] = "Entrar na Arena";
    Layout = "_Layout";
}

<section class="bg-dark min-vh-75 d-flex align-items-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card bg-dark-card border-secondary shadow">
                    <div class="card-body p-4">
                        <h3 class="text-white text-center fw-bold mb-1">Login</h3>
                        <p class="text-secondary text-center small mb-4">Entre para gerenciar seus games</p>

                        <form asp-action="Index" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label text-light small fw-bold"></label>
                                <input asp-for="Email" class="form-control bg-secondary border-0 text-light"
                                       placeholder="seu@email.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Senha" class="form-label text-light small fw-bold"></label>
                                <input asp-for="Senha" type="password"
                                       class="form-control bg-secondary border-0 text-light"
                                       placeholder="••••••" />
                                <span asp-validation-for="Senha" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-success w-100 fw-bold py-2">
                                <i class="bi bi-box-arrow-in-right"></i> Acessar Arena
                            </button>
                        </form>

                        <div class="text-center mt-4">
                            <span class="text-secondary small">Ainda não tem uma conta?</span><br />
                            <a asp-action="CriarConta" class="text-danger text-decoration-none fw-bold">
                                Criar nova conta
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
