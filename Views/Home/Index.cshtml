@model IEnumerable<Game>
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Banner -->
<section class="hero-banner position-relative overflow-hidden">
    <div class="hero-overlay"></div>
    <div class="container position-relative" style="z-index: 2;">
        <div class="row min-vh-50 align-items-center py-5">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold text-white mb-3">Domine o Jogo</h1>
                <p class="lead text-light mb-4">
                    Os lançamentos mais esperados e as melhores ofertas em um só lugar.
                    Upgrade no seu setup começa aqui.
                </p>
                <a href="#destaque" class="btn btn-success btn-lg px-4">
                    <i class="bi bi-controller"></i> Ver Ofertas
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Categorias -->
<section class="py-3 bg-dark">
    <div class="container text-center">
        <span class="badge bg-secondary rounded-pill px-3 py-2 mx-1">RPG</span>
        <span class="badge bg-secondary rounded-pill px-3 py-2 mx-1">Ação</span>
        <span class="badge bg-secondary rounded-pill px-3 py-2 mx-1">Corrida</span>
        <span class="badge bg-secondary rounded-pill px-3 py-2 mx-1">Aventura</span>
    </div>
</section>

<!-- Games Em Destaque -->
<section id="destaque" class="py-5 bg-dark">
    <div class="container">
        <h2 class="text-white mb-4 fw-bold">Em Destaque</h2>
        <div class="row g-4">
            @foreach (var game in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card bg-dark-card border-secondary h-100 game-card">
                        @if (!string.IsNullOrEmpty(game.ImagemUrl))
                        {
                            <img src="@game.ImagemUrl" class="card-img-top" alt="@game.Titulo"
                                 style="height: 200px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
                                 style="height: 200px;">
                                <i class="bi bi-controller display-3 text-light"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-white">@game.Titulo</h5>
                            <p class="card-text text-secondary small flex-grow-1">@game.Descricao</p>
                            <div>
                                <span class="text-success fw-bold fs-5">
                                    R$ @game.Preco.ToString("N2")
                                </span>
                            </div>
                            <a href="#" class="btn btn-success mt-2 w-100">
                                <i class="bi bi-cart-plus"></i> Comprar
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-controller display-1 text-secondary"></i>
                <p class="text-secondary mt-3">Nenhum game cadastrado ainda.</p>
            </div>
        }
    </div>
</section>
